# ============================================
# Kipit - Configuration
# ============================================

# Session (32 caractères minimum)
NUXT_SESSION_PASSWORD=your-secret-at-least-32-characters-long

# Turso Database (https://turso.tech - gratuit)
TURSO_DB_URL=libsql://your-db-name-your-org.turso.io
TURSO_DB_TOKEN=your-auth-token-here

# Resend (https://resend.com - emails, optionnel)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NOWPayments (https://nowpayments.io - paiement crypto)
NOWPAYMENTS_API_KEY=your-api-key-here
NOWPAYMENTS_IPN_SECRET=your-ipn-secret-here

# App URL (pour les callbacks de paiement)
APP_URL=https://your-app.vercel.app
